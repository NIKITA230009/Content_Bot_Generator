BOT_TOKEN=
ADMIN_CHAT_ID=0

# Формат: JSON. Ключ — ID канала-источника, значение — массив ID каналов-целей
# Пример: {"-1001234567890": [-1001111111111, -1002222222222]}
SOURCE_TARGET_MAP_RAW={}
PUBLISH_INTERVALS_RAW={}

MEDIA_AGGREGATION_TIMEOUT=10

DATABASE_URL=postgresql+asyncpg://user:pass@localhost:5432/content_bot
REDIS_URL=redis://localhost:6379/0

OPENROUTER_API_KEY=
MODEL_NAME=deepseek/deepseek-chat
MODEL_TEMPERATURE=0.7
MODEL_MAX_TOKENS=1024

# Telethon (MTProto) — для чтения чужих каналов без прав админа
# API_ID и API_HASH получить: https://my.telegram.org/apps
# TELETHON_PHONE — ваш номер с кодом страны
TELETHON_API_ID=0
TELETHON_API_HASH=
TELETHON_PHONE=
